rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. User Profiles
    // Users can only read and write their own specific document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // 2. Savings Groups
    match /groups/{groupId} {
      // Allow anyone to check if a group exists (needed for invitation code validation)
      allow get: if true;
      
      // Allow authenticated users to create a new group
      allow create: if request.auth != null;
      
      // Allow authenticated users to update a group (e.g., joining)
      allow update: if request.auth != null;
    }
  }
}